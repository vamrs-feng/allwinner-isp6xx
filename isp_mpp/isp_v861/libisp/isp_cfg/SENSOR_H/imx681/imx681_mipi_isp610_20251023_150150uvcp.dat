			<Item Name="Tolerance" Type="EditSlider" TypeVal="" Radix="10" MinVal="1" MaxVal="256" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="PLTM容忍度\n改值越大，在一定的亮度区间内PLTM越不容易抖动">54</Item>
			<Item Name="Gtm Enable" Type="Bool" TypeVal="Disable;Enable" Radix="" MinVal="" MaxVal="" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="PLTM全局映射曲线使能">0</Item>
			<Item Name="Ltf Enable" Type="Bool" TypeVal="Disable;Enable" Radix="" MinVal="" MaxVal="" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="PLTM增益行使能，打开后PLTM将进行行内像素点增益平滑，提升部分弱纹理细节对比度，将会使得噪声被放大">1</Item>
			<Item Name="Dcc Enable" Type="Bool" TypeVal="Disable;Enable" Radix="" MinVal="" MaxVal="" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="PLTM暗部对比度控制使能，打开后PLTM将进行暗部增益值控制，对暗部增益值根据亮度进行限制以达到增强全局对比度的作用">1</Item>
			<Item Name="Dcc Shf Bit" Type="EditSlider" TypeVal="" Radix="10" MinVal="0" MaxVal="3" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="增益PLTM输入亮度移位位数">0</Item>
			<Item Name="Dcc Lw Th" Type="EditSlider" TypeVal="" Radix="10" MinVal="0" MaxVal="4095" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="暗部对比度控制低阈值，用于选择DCC系数过渡区\n当亮度小于该值，则认为是完全暗部">64</Item>
			<Item Name="Dcc Hi Th" Type="EditSlider" TypeVal="" Radix="10" MinVal="0" MaxVal="4095" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="暗部对比度控制高阈值，用于选择DCC系数过渡区\n当亮度大于该值，则认为是正常非暗块">333</Item>
			<Item Name="Dsc Enable" Type="Bool" TypeVal="Disable;Enable" Radix="" MinVal="" MaxVal="" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="PLTM暗部饱和度控制使能\n打开后PLTM将进行暗部饱和度控制，对暗部饱和度进行降低，防止暗部饱和度提升过多">1</Item>
			<Item Name="Dsc Shf Bit" Type="EditSlider" TypeVal="" Radix="10" MinVal="0" MaxVal="3" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="PLTM输入亮度移位位数">0</Item>
			<Item Name="Dsc Lw Th" Type="EditSlider" TypeVal="" Radix="10" MinVal="0" MaxVal="4095" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="亮度控制低阈值，用于选择DSC过渡区\n当亮度小于该值，则认为全需要控制饱和度">32</Item>
			<Item Name="Dsc Hi Th" Type="EditSlider" TypeVal="" Radix="10" MinVal="0" MaxVal="4095" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="亮度控制高阈值，用于选择DSC过渡区\n当亮度大于该值，则认为不需要控制饱和度">128</Item>
			<Item Name="Mgc Int Smth" Type="EditSlider" TypeVal="" Radix="10" MinVal="0" MaxVal="255" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="融合平滑度控制，用于控制分阶加权平滑度\n该值越大，融合平滑度越高，越不容易出现水波纹现象，暗部提升作用越明显">32</Item>
			<Item Name="Mgc Lum Adpt" Type="EditSlider" TypeVal="" Radix="10" MinVal="0" MaxVal="15" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="融合亮度自适应参数，用于控制高亮区域对比度\n该值越大，高亮区域越不容易过曝，但画面的整体对比度下降">15</Item>
			<Item Name="Sts Ceil Slope" Type="EditSlider" TypeVal="" Radix="10" MinVal="32" MaxVal="1023" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="暗部最大增益斜率\n大于该斜率部分的增益值将会进行限制">512</Item>
			<Item Name="Sts Floor Slope" Type="EditSlider" TypeVal="" Radix="10" MinVal="63" MaxVal="1023" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="亮度最大下拉斜率\n小于该斜率部分的增益值会进行限制">64</Item>
			<Item Name="Sts Guide Ratio" Type="EditSlider" TypeVal="" Radix="10" MinVal="16" MaxVal="255" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="控制引导曲线作用比例\n该值越大，引导曲线的作用越强">32</Item>
			<Item Name="Adjk Crct Ratio" Type="EditSlider" TypeVal="" Radix="10" MinVal="0" MaxVal="255" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="用于控制k阶矫正时的矫正强度\n该值越大，边缘效应越弱，对比度下降">255</Item>
			<Item Name="Interval frame" Type="EditSlider" TypeVal="" Radix="10" MinVal="0" MaxVal="10" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="PLTM算法生效的间隔帧数">3</Item>
			<Item Name="Dark Low Th" Type="EditSlider" TypeVal="" Radix="10" MinVal="0" MaxVal="4096" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="PLTM判断黑块低阈值">128</Item>
			<Item Name="Dark High Th" Type="EditSlider" TypeVal="" Radix="10" MinVal="0" MaxVal="4096" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="PLTM判断黑块高阈值">384</Item>
			<Item Name="Darknest Num" Type="EditSlider" TypeVal="" Radix="10" MinVal="1" MaxVal="192" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="暂无作用">9</Item>
			<Item Name="Reserve0" Type="EditSlider" TypeVal="" Radix="10" MinVal="0" MaxVal="4095" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="暂无作用">0</Item>
			<Item Name="Reserve1" Type="EditSlider" TypeVal="" Radix="10" MinVal="0" MaxVal="4095" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="暂无作用">0</Item>
			<Item Name="Reserve2" Type="EditSlider" TypeVal="" Radix="10" MinVal="0" MaxVal="4095" CfgId="0x00000400" DataType="S32" RWMode="ReadWrite" Description="暂无作用">0</Item>
