			<Item Name="NDIR-MS" Type="Matrix" TypeVal="14x6:*:Edge Th;Flat Th;Black Stren;White Stren;Black Clip;White Clip" Radix="" MinVal="" MaxVal="" CfgId="0x00040000" DataType="S16" RWMode="ReadWrite" Description="中频无方向锐化边缘区域阈值 Range:[0，255]\n阈值越小，容易出现部分区域清晰度不足\n阈值越大，强边缘平滑度保护越弱，容易出现强边锯齿/不连续现象;中频无方向锐化平坦区域阈值 Range:[0，255]\n阈值越小，容易出现平坦区域噪声被放大\n阈值越大，平坦区域噪声抑制越明显，容易造成清晰度下降;中频无方向锐化黑边强度 Range:[0，4095]\n强度越小，黑边锐化越弱\n强度越大，黑边锐化越强;中频无方向锐化白边强度 Range:[0，4095]\n强度越小，白边锐化越弱\n强度越大，白边锐化越强;中频无方向锐化后黑边过冲控制 Range:[0，1024]\n数值越小，黑边过冲限制越强，边缘不容易过黑\n数值越大，黑边过冲限制越弱，边缘黑边越明显;中频无方向锐化后白边过冲控制 Range:[0，1024]\n数值越小，白边过冲限制越强，边缘不容易过白\n数值越大，白边过冲限制越弱，边缘白边越明显">64,2,66,66,133,22,64,2,66,66,133,22,64,2,66,66,133,22,128,4,66,66,133,22,128,4,66,66,133,22,128,4,66,66,133,22,128,4,66,66,66,22,128,4,66,66,32,22,128,4,66,66,32,22,128,4,66,66,32,32,128,4,66,66,32,32,128,4,66,66,32,32,128,4,66,66,32,32,128,4,66,66,32,32</Item>
			<Item Name="COMM" Type="Matrix" TypeVal="14x10:*:Ndir Hs Mix Lw Clip;Ndir Hs Mix Hi Clip;Ndir Ms Mix Lw Clip;Ndir Ms Mix Hi Clip;Black Clip Ratio;White Clip Ratio;Motion Ratio;Static Ratio;Flat Ratio;Texture Ratio" Radix="" MinVal="" MaxVal="" CfgId="0x00040000" DataType="S16" RWMode="ReadWrite" Description="无方向高频锐化混叠系数下限 Range:[0，255]\n该值越小，混叠比例不做限制，越多区域无法叠加上无方向锐化，清晰度越低\n该值越大，越多区域会叠加上无方向锐化，清晰度越高;无方向高频锐化混叠系数上限 Range:[0，255]\n该值越小，混叠比例限制越小，混叠比例限制越强，混叠的无方向锐化强度将会降低\n该值越大，混叠限制越小;无方向中频锐化混叠系数下限 Range:[0，255]\n该值越小，混叠比例不做限制，越多区域无法叠加上无方向锐化，清晰度越低\n该值越大，越多区域会叠加上无方向锐化，清晰度越高;无方向中频锐化混叠系数上限 Range:[0，255]\n该值越小，混叠比例限制越小，混叠比例限制越强，混叠的无方向锐化强度将会降低\n该值越大，混叠限制越小;锐化最后输出的黑边过冲控制 Range:[0，1024]\n该值越小，黑边过冲限制越强，边缘不容易过黑\n数值越大，黑边过冲限制越弱，边缘黑边越明显;锐化最后输出的白边过冲控制 Range:[0，1024]\n数值越小，白边过冲限制越强，边缘不容易过白\n数值越大，白边过冲限制越弱，边缘白边越明显;运动区域锐化比例系数 Range:[0，255]\n该值越大，运动区域锐化越强\n反之，运动区域锐化越弱;静止区域锐化比例系数 Range:[0，255]\n该值越大，静止区域锐化越强\n反之，静止区域锐化越弱;平坦区域锐化比例系数 Range:[0，255]\n该值越大，平坦区域锐化越强\n反之，平坦区域锐化越弱;纹理区域锐化比例系数 Range:[0，255]\n该值越大，纹理区域锐化越强\n反之，纹理区域锐化越弱">1,255,1,255,1023,1022,1023,1022,240,255,1,255,1,255,1023,1022,1023,1022,240,255,1,255,1,255,1023,1022,1023,1022,240,255,1,255,1,255,1023,1022,1023,1022,192,255,1,255,1,255,1023,1022,1023,1022,160,255,1,255,1,255,1023,1022,1023,1022,128,255,1,255,1,255,1023,1022,1023,1022,128,255,1,255,1,255,102,102,1023,1022,128,255,1,255,1,255,102,102,1023,1022,188,255,1,255,1,255,1023,1022,1023,1022,188,255,1,255,1,255,1023,1022,1023,1022,240,255,1,255,1,255,1023,1022,1023,1022,240,255,1,255,1,255,1023,1022,1023,1022,240,255,1,255,1,255,1023,1022,1023,1022,240,255</Item>
		</Pane>
