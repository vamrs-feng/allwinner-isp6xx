			<Item Name="Dir Ls Lum Cv Enable" Type="Bool" TypeVal="Disable;Enable" Radix="" MinVal="" MaxVal="" CfgId="0x00004000" DataType="S16" RWMode="ReadWrite" Description="方向低频锐化亮度曲线使能\n一般建议默认打开">1</Item>
